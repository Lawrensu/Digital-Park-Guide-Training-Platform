allow-build[]=@parcel/watcher
allow-build[]=@prisma/engines
allow-build[]=prisma

# Metro bundler cannot follow pnpm's virtual store symlinks for packages injected
# at transform time (e.g. @babel/runtime) or by NativeWind (react-native-css-interop).
# shamefully-hoist makes pnpm behave like npm: every package in the dep tree gets
# a symlink in the workspace root node_modules, so Metro always finds what it needs.
shamefully-hoist=true
