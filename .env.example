# AWS (IAM user with AmazonS3FullAccess + AmazonSESFullAccess, ap-southeast-1)
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_IOT_ENDPOINT=

# SES
SES_REGION=ap-southeast-1
SES_FROM_EMAIL=

# Database
DATABASE_URL=postgresql://user:password@localhost:5433/sfcpark

# Redis (Upstash — format: rediss://default:PASSWORD@HOST:PORT)
REDIS_URL=

# JWT
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# IoT ingest internal secret (must match x-internal-secret header from IoT Core rule)
INTERNAL_SECRET=

# App
PORT=3000
NODE_ENV=development

# Client URLs (for CORS)
WEB_URL=http://localhost:5173
MOBILE_URL=exp://localhost:8081

# BillPlz
BILLPLZ_SANDBOX=true
BILLPLZ_API_KEY=
BILLPLZ_COLLECTION_ID=
BILLPLZ_X_SIGNATURE=

# Seed — primary admin account (used by prisma db seed)
SEED_ADMIN_USERNAME=
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
