# Database
DATABASE_URL=postgresql://user:password@localhost:5432/sfcpark

# Redis (Upstash — format: rediss://default:PASSWORD@HOST:PORT)
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# AWS (Learner Lab: get all three from lab AWS Details each session)
# S3 and SES restricted to us-east-1 on this teaching account
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_S3_BUCKET=
AWS_IOT_ENDPOINT=

# Email (AWS SES — verify sender identity in SES console first)
SES_FROM_EMAIL=
SES_REGION=us-east-1

# BillPlz (sandbox: switch to sandbox mode in billplz.com settings)
BILLPLZ_API_KEY=
BILLPLZ_COLLECTION_ID=
BILLPLZ_X_SIGNATURE=
BILLPLZ_SANDBOX=true

# App
PORT=3000
NODE_ENV=development

# Client URLs (for CORS)
WEB_URL=http://localhost:5173
MOBILE_URL=exp://localhost:8081

# Seed — primary admin account (used by prisma db seed)
SEED_ADMIN_USERNAME=
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
