# Database
DATABASE_URL=postgresql://user:password@localhost:5432/sfcpark

# Redis (Upstash — use rediss:// for TLS, e.g. rediss://default:PASSWORD@HOST:PORT)
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# AWS
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_IOT_ENDPOINT=

# Email (AWS SES — verify sender identity in SES console first)
SES_FROM_EMAIL=
SES_REGION=ap-southeast-1

# App
PORT=3000
NODE_ENV=development

# Client URLs (for CORS)
WEB_URL=http://localhost:5173
MOBILE_URL=exp://localhost:8081

# Seed — primary admin account (used by prisma db seed)
SEED_ADMIN_USERNAME=
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=